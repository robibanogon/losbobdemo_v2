# Backend Environment Variables

# Server Configuration
PORT=3001
NODE_ENV=development

# JWT Configuration
JWT_SECRET=los-demo-secret-key-change-in-production

# File Storage
DATA_DIR=./data
UPLOAD_DIR=./data/uploads

# CORS Configuration (optional)
# CORS_ORIGIN=http://localhost:5173

# IBM watsonx.ai Configuration
# Get your API key from: https://cloud.ibm.com/iam/apikeys
# Get your project ID from: https://dataplatform.cloud.ibm.com/projects
WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSONX_API_URL=https://us-south.ml.cloud.ibm.com/ml/v1/text/generation?version=2023-05-29
WATSONX_DEFAULT_MODEL=llama-3-3-70b-instruct

# Available models:
# - llama-3-3-70b-instruct (Meta Llama 3.3 70B - Strong reasoning, multilingual)
# - gpt-oss-120b (IBM GPT OSS 120B - Large scale, comprehensive analysis)
# - granite-13b-instruct (IBM Granite 13B - Optimized for business tasks)

# IBM Cloud Object Storage Configuration
# Get your credentials from: https://cloud.ibm.com/objectstorage
# Create a service credential with HMAC enabled
IBM_COS_API_KEY=your_ibm_cos_api_key_here
IBM_COS_INSTANCE_ID=your_ibm_cos_instance_id_here
IBM_COS_ENDPOINT=s3.us-south.cloud-object-storage.appdomain.cloud
IBM_COS_BUCKET_NAME=loan-documents

# IBM COS Endpoints by Region:
# - us-south: s3.us-south.cloud-object-storage.appdomain.cloud
# - us-east: s3.us-east.cloud-object-storage.appdomain.cloud
# - eu-gb: s3.eu-gb.cloud-object-storage.appdomain.cloud
# - eu-de: s3.eu-de.cloud-object-storage.appdomain.cloud
# - ap-geo: s3.ap.cloud-object-storage.appdomain.cloud